# ============================================================================
# THIS FILE IS COMMITTED TO GIT.
# DO NOT PUT SECRETS HERE.
#
# Real secrets (NEXTAUTH_SECRET, ENCRYPTION_KEY, GOOGLE_CLIENT_SECRET, etc.)
# live in .env.local, which IS gitignored (via .env*.local).
#
# The only reason this file is committed is so the Prisma CLI — which only
# autoloads .env and does NOT read .env.local — can resolve DATABASE_URL
# for migrate and generate commands during local development.
#
# The DATABASE_URL below points at the docker-compose Postgres on localhost
# with throwaway dev credentials. No production data is ever here.
# ============================================================================

DATABASE_URL="postgresql://expense:expense_dev@localhost:5433/expense_tracker?schema=public"

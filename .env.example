# Database
DATABASE_URL="postgresql://expense:expense_dev@localhost:5433/expense_tracker?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# Encryption for Gmail tokens at rest (64 hex chars = 32 bytes)
ENCRYPTION_KEY=""

# Google OAuth (Gmail readonly)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# App
# NODE_ENV is set by Next.js automatically (build=production, dev=development).
# Do NOT set it here — doing so triggers Next.js "non-standard NODE_ENV" warnings
# and causes mismatched dev/prod React runtime during `next build`.

